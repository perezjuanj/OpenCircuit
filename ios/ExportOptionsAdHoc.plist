<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Ad-hoc distribution: produces a sideloadable .ipa (installable on devices whose
	     UDIDs are registered to the team). Used to export from an existing .xcarchive for
	     a GitHub release asset. Does NOT upload; leaves the .ipa on disk. -->
	<key>method</key>
	<string>ad-hoc</string>
	<key>teamID</key>
	<string>765RD9BJ8C</string>
	<key>signingStyle</key>
	<string>automatic</string>
	<key>destination</key>
	<string>export</string>
	<key>uploadSymbols</key>
	<true/>
	<!-- Thin to a universal IPA so it installs on any registered arm64 device. -->
	<key>thinning</key>
	<string>&lt;none&gt;</string>
</dict>
</plist>
